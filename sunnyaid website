<script>
// ── CLOCK ──
function updateClock(){
  const now = new Date();
  const t = now.toLocaleTimeString('en-AU',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const ds = now.toLocaleDateString('en-AU',{weekday:'short',day:'numeric',month:'short',year:'numeric'});
  const dl = now.toLocaleDateString('en-AU',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  document.getElementById('navTime').textContent = t;
  document.getElementById('navDate').textContent = ds;
  document.getElementById('chatTime').textContent = t;
  document.getElementById('chatDate').textContent = dl;
  document.getElementById('initMsgTime').textContent = now.toLocaleTimeString('en-AU',{hour:'2-digit',minute:'2-digit'});
}
setInterval(updateClock, 1000);
updateClock();

// ── NAV SCROLL ──
window.addEventListener('scroll', () => {
  document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 60);
  let cur = '';
  document.querySelectorAll('section[id], div[id]').forEach(s => {
    if (s.offsetTop - 90 <= window.scrollY) cur = s.id;
  });
  document.querySelectorAll('.nav-links a').forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#' + cur);
  });
});

// ── MOBILE MENU ──
function openMob()  { document.getElementById('mobMenu').classList.add('open'); }
function closeMob() { document.getElementById('mobMenu').classList.remove('open'); }

// ── SCROLL REVEAL ──
const ro = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); });
}, { threshold: .12 });
document.querySelectorAll('.reveal, .scard, .tcard, .acard, .aw-b, .erow, .pcard, .art-card, .hcard, .step, .hero-stat, .qr-card').forEach(el => {
  el.classList.add('reveal'); ro.observe(el);
});

// ── QR CODES ──
const QR_DATA = {
  phone: { url: 'tel:+61889675083',           icon: '📞', title: 'Call SunnyAid',  sub: 'Point your camera to dial instantly',       val: '+61-8-8967-5083'      },
  email: { url: 'mailto:info@sunnyaid.com.au', icon: '✉️', title: 'Email SunnyAid', sub: 'Scan to open a new email to our team',     val: 'info@sunnyaid.com.au' },
  web:   { url: 'https://www.sunnyaid.com.au', icon: '🌐', title: 'Visit Website',  sub: 'Scan to open SunnyAid in your browser',   val: 'www.sunnyaid.com.au'  }
};

function makeQR(id, url, size) {
  const el = document.getElementById(id);
  if (!el) return;
  el.innerHTML = '';
  new QRCode(el, { text: url, width: size, height: size, colorDark: '#0d3347', colorLight: '#ffffff', correctLevel: QRCode.CorrectLevel.H });
}

window.addEventListener('load', () => {
  makeQR('qr-phone', QR_DATA.phone.url, 130);
  makeQR('qr-email', QR_DATA.email.url, 130);
  makeQR('qr-web',   QR_DATA.web.url,   130);
});

function openQR(key) {
  const d = QR_DATA[key];
  document.getElementById('qrMIcon').textContent = d.icon;
  document.getElementById('qrMTitle').textContent = d.title;
  document.getElementById('qrMSub').textContent   = d.sub;
  document.getElementById('qrMVal').textContent   = d.val;
  makeQR('qr-large', d.url, 182);
  document.getElementById('qrOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeQR(e) {
  if (!e || e.target === document.getElementById('qrOverlay') || !e.target) {
    document.getElementById('qrOverlay').classList.remove('open');
    document.body.style.overflow = '';
  }
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeQR(); });

// ── CHAT ──
const SYS = `You are a friendly and knowledgeable support assistant for SunnyAid, an Australian NDIS (National Disability Insurance Scheme) registered disability services provider. Speak in a warm, helpful, Australian-friendly tone.

About SunnyAid:
- 26+ years as a trusted NDIS provider
- Registered Provider #4050072735
- Coverage: Queensland, NSW & ACT, Victoria, Western Australia
- Phone: +61-8-8967-5083
- Email: info@sunnyaid.com.au
- 220+ expert team members, 98% client satisfaction

Services:
1. Therapeutic Support
2. Daily Living & Life Skills
3. Support & Connection
4. Daily Life Assistance
5. NDIS Speech Therapy
6. Community & Activities
7. NDIS Plan Management
8. Specialist Support Coordination

Getting started: Make enquiry → Create NDIS Plan → Start Exceptional Care
Keep responses concise (2-4 sentences), helpful and warm. For urgent help direct to +61-8-8967-5083.`;

let history = [], chatOpen = false;

function toggleChat() {
  chatOpen = !chatOpen;
  document.getElementById('chatWin').classList.toggle('open', chatOpen);
  document.getElementById('chatNotif').style.display = chatOpen ? 'none' : 'flex';
  if (chatOpen) document.getElementById('chatIn').focus();
}

function getT() { return new Date().toLocaleTimeString('en-AU',{hour:'2-digit',minute:'2-digit'}); }

function addMsg(txt, role) {
  const c = document.getElementById('chatMsgs');
  const d = document.createElement('div');
  d.className = `msg ${role}`;
  d.innerHTML = `<div class="msg-b">${txt}</div><div class="msg-t">${getT()}</div>`;
  c.appendChild(d); c.scrollTop = c.scrollHeight;
}

function showTyping() {
  const c = document.getElementById('chatMsgs');
  const d = document.createElement('div');
  d.className = 'msg bot'; d.id = 'typo';
  d.innerHTML = '<div class="msg-b"><div class="typing"><span></span><span></span><span></span></div></div>';
  c.appendChild(d); c.scrollTop = c.scrollHeight;
}

function removeTyping() { const t = document.getElementById('typo'); if (t) t.remove(); }

function sendQ(txt) {
  document.getElementById('chatIn').value = txt;
  document.getElementById('chatQR').style.display = 'none';
  sendMsg();
}

async function sendMsg() {
  const inp = document.getElementById('chatIn');
  const txt = inp.value.trim(); if (!txt) return;
  inp.value = '';
  addMsg(txt, 'user');
  history.push({ role: 'user', content: txt });
  showTyping();
  try {
    const r = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 1000, system: SYS, messages: history })
    });
    const data = await r.json();
    removeTyping();
    const rep = data.content?.[0]?.text || "I'm sorry, I couldn't process that. Please call us on +61-8-8967-5083.";
    addMsg(rep, 'bot');
    history.push({ role: 'assistant', content: rep });
  } catch (err) {
    removeTyping();
    addMsg("Sorry, I'm having trouble connecting right now. Please call us on 📞 +61-8-8967-5083 and we'll be happy to help!", 'bot');
  }
}
</script>
