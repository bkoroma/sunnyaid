.ch-send{background:linear-gradient(135deg,var(--teal),var(--teal-mid));border:none;color:var(--white);width:40px;height:40px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.2s;flex-shrink:0;}
