<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SunnyAid – NDIS Disability Services Australia</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
:root {
  --teal: #0d3347;
  --teal-mid: #1a4d6b;
  --teal-light: #2a6f94;
  --gold: #d4952a;
  --gold-bright: #f0b73a;
  --cream: #f8f4ee;
  --white: #ffffff;
  --text: #0d1f2d;
  --text-mid: #4a6070;
  --text-light: #7a9aaa;
  --border: rgba(13,51,71,0.1);
  --shadow-sm: 0 2px 12px rgba(13,51,71,0.08);
  --shadow: 0 8px 32px rgba(13,51,71,0.12);
  --shadow-lg: 0 20px 60px rgba(13,51,71,0.18);
  --nav-h: 80px;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Outfit',sans-serif;color:var(--text);background:var(--white);overflow-x:hidden;}
::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-track{background:#f0ead8;}
::-webkit-scrollbar-thumb{background:var(--teal-light);border-radius:3px;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;height:var(--nav-h);background:rgba(255,255,255,0.96);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 5%;box-shadow:var(--shadow-sm);transition:.3s;}
nav.scrolled{background:rgba(13,51,71,0.97);}
nav.scrolled .nav-links a{color:rgba(255,255,255,0.8);}
nav.scrolled .nav-links a:hover,nav.scrolled .nav-links a.active{color:var(--gold-bright);}
nav.scrolled .nav-logo{color:var(--white);}
nav.scrolled .nav-time{color:var(--gold-bright);}
nav.scrolled .nav-date{color:rgba(255,255,255,0.55);}
nav.scrolled .hamburger span{background:var(--white);}
.nav-brand{display:flex;align-items:center;gap:12px;text-decoration:none;}
.nav-icon{width:42px;height:42px;background:linear-gradient(135deg,var(--teal),var(--teal-mid));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;}
.nav-logo{font-family:'Playfair Display',serif;font-size:1.45rem;color:var(--teal);font-weight:700;}
.nav-logo span{color:var(--gold);}
.nav-links{display:flex;gap:28px;list-style:none;margin:0 auto;}
.nav-links a{text-decoration:none;color:var(--text-mid);font-weight:500;font-size:.9rem;transition:.2s;position:relative;padding-bottom:3px;}
.nav-links a::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--gold);border-radius:1px;transform:scaleX(0);transition:.25s;}
.nav-links a:hover::after,.nav-links a.active::after{transform:scaleX(1);}
.nav-links a:hover,.nav-links a.active{color:var(--teal);}
.nav-right{display:flex;align-items:center;gap:16px;}
.nav-datetime{text-align:right;line-height:1.35;}
.nav-time{font-size:.95rem;font-weight:700;color:var(--teal);font-family:'Playfair Display',serif;display:block;}
.nav-date{font-size:.7rem;color:var(--text-light);font-weight:500;display:block;}
.nav-cta{background:linear-gradient(135deg,var(--gold),var(--gold-bright));color:var(--teal);padding:10px 22px;border-radius:50px;font-weight:700;font-size:.85rem;text-decoration:none;display:flex;align-items:center;gap:8px;transition:.25s;white-space:nowrap;box-shadow:0 4px 16px rgba(212,149,42,0.35);}
.nav-cta:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(212,149,42,0.45);}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;border:none;background:none;padding:4px;}
.hamburger span{width:24px;height:2px;background:var(--text);border-radius:2px;transition:.3s;}

/* HERO */
#hero{min-height:100vh;background:linear-gradient(160deg,var(--teal) 0%,var(--teal-mid) 45%,#1e5c7a 100%);display:flex;align-items:center;padding:calc(var(--nav-h)+60px) 5% 80px;position:relative;overflow:hidden;}
.hero-geo{position:absolute;inset:0;pointer-events:none;}
.hero-geo::before{content:'';position:absolute;top:-200px;right:-200px;width:700px;height:700px;background:radial-gradient(circle,rgba(212,149,42,0.12),transparent 65%);border-radius:50%;}
.hero-geo::after{content:'';position:absolute;bottom:-150px;left:-100px;width:500px;height:500px;background:radial-gradient(circle,rgba(255,255,255,0.04),transparent 70%);border-radius:50%;}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px);background-size:60px 60px;}
.hero-inner{max-width:1200px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;position:relative;z-index:1;}
.hero-pill{display:inline-flex;align-items:center;gap:8px;background:rgba(212,149,42,0.15);border:1px solid rgba(212,149,42,0.3);color:var(--gold-bright);font-size:.75rem;font-weight:700;letter-spacing:.12em;padding:7px 16px;border-radius:50px;margin-bottom:28px;text-transform:uppercase;}
.hero-dot{width:6px;height:6px;background:var(--gold-bright);border-radius:50%;animation:blink 2s infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:.3;}}
h1.hero-title{font-family:'Playfair Display',serif;font-size:clamp(2.4rem,4.5vw,3.8rem);line-height:1.12;color:var(--white);margin-bottom:24px;font-weight:900;}
h1.hero-title em{color:var(--gold-bright);font-style:italic;}
.hero-desc{font-size:1.05rem;color:rgba(255,255,255,0.72);line-height:1.8;margin-bottom:40px;max-width:480px;}
.hero-btns{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:56px;}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold-bright));color:var(--teal);padding:14px 30px;border-radius:50px;font-weight:700;font-size:.93rem;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:.25s;box-shadow:0 6px 20px rgba(212,149,42,0.4);}
.btn-gold:hover{transform:translateY(-3px);box-shadow:0 12px 30px rgba(212,149,42,0.5);}
.btn-ghost{background:rgba(255,255,255,0.1);color:var(--white);border:1.5px solid rgba(255,255,255,0.25);padding:14px 30px;border-radius:50px;font-weight:600;font-size:.93rem;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:.25s;backdrop-filter:blur(8px);}
.btn-ghost:hover{background:rgba(255,255,255,0.18);transform:translateY(-3px);}
.hero-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,0.1);border-radius:16px;overflow:hidden;}
.hero-stat{background:rgba(255,255,255,0.06);padding:20px;text-align:center;}
.hero-stat-num{font-family:'Playfair Display',serif;font-size:2.2rem;color:var(--gold-bright);font-weight:700;line-height:1;}
.hero-stat-label{font-size:.75rem;color:rgba(255,255,255,0.6);margin-top:4px;font-weight:500;}
.hero-visual{position:relative;}
.hero-cards{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.hcard{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:18px;padding:24px;backdrop-filter:blur(12px);transition:.3s;}
.hcard:hover{background:rgba(255,255,255,0.12);transform:translateY(-4px);}
.hcard-icon{width:48px;height:48px;background:linear-gradient(135deg,var(--gold),var(--gold-bright));border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;margin-bottom:14px;}
.hcard h4{color:var(--white);font-weight:600;font-size:.93rem;margin-bottom:6px;}
.hcard p{color:rgba(255,255,255,0.6);font-size:.8rem;line-height:1.55;}
.hcard.wide{grid-column:1/-1;display:flex;gap:20px;align-items:center;}
.hcard.wide .hcard-icon{flex-shrink:0;width:56px;height:56px;font-size:1.5rem;}
.hero-float{position:absolute;bottom:-20px;right:-20px;background:var(--white);border-radius:14px;padding:14px 20px;box-shadow:var(--shadow-lg);display:flex;align-items:center;gap:12px;}
.hf-icon{width:40px;height:40px;background:linear-gradient(135deg,#2ecc71,#27ae60);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;}
.hf-text strong{display:block;font-size:.88rem;color:var(--teal);}
.hf-text span{font-size:.75rem;color:var(--text-mid);}

/* TRUST BAR */
.trust-bar{background:var(--gold);padding:18px 5%;}
.trust-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;}
.trust-text{font-weight:700;color:var(--teal);font-size:.9rem;}
.trust-items{display:flex;gap:32px;align-items:center;flex-wrap:wrap;}
.trust-item{font-weight:600;font-size:.85rem;color:var(--teal);}

/* SHARED */
section{padding:100px 5%;}
.si{max-width:1200px;margin:0 auto;}
.eyebrow{display:block;text-align:center;font-size:.72rem;font-weight:800;letter-spacing:.2em;color:var(--gold);text-transform:uppercase;margin-bottom:14px;}
.sec-title{font-family:'Playfair Display',serif;font-size:clamp(2rem,3.5vw,2.9rem);text-align:center;color:var(--teal);margin-bottom:18px;line-height:1.2;}
.sec-title em{color:var(--gold);font-style:italic;}
.sec-desc{text-align:center;color:var(--text-mid);max-width:520px;margin:0 auto 64px;line-height:1.8;font-size:.97rem;}

/* ABOUT */
#about{background:linear-gradient(160deg,var(--teal),var(--teal-mid));padding:100px 5%;position:relative;overflow:hidden;}
#about::before{content:'';position:absolute;top:-100px;right:-100px;width:500px;height:500px;background:radial-gradient(circle,rgba(212,149,42,0.08),transparent 65%);border-radius:50%;}
.about-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;position:relative;z-index:1;}
.about-ey{font-size:.72rem;font-weight:800;letter-spacing:.2em;color:var(--gold-bright);text-transform:uppercase;display:block;margin-bottom:14px;}
.about-inner h2{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3vw,2.6rem);color:var(--white);margin-bottom:20px;line-height:1.2;}
.about-inner>div>p{color:rgba(255,255,255,0.72);line-height:1.8;margin-bottom:32px;}
.about-stats{display:flex;gap:40px;margin-bottom:36px;}
.ast{border-left:3px solid var(--gold);padding-left:18px;}
.ast-num{font-family:'Playfair Display',serif;font-size:2.4rem;color:var(--gold-bright);line-height:1;}
.ast-lbl{color:rgba(255,255,255,0.6);font-size:.8rem;margin-top:4px;}
.about-cards{display:flex;flex-direction:column;gap:16px;}
.acard{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:22px 24px;display:flex;gap:18px;align-items:flex-start;transition:.3s;}
.acard:hover{background:rgba(255,255,255,0.12);transform:translateX(4px);}
.acard-icon{width:46px;height:46px;background:linear-gradient(135deg,var(--gold),var(--gold-bright));border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;}
.acard h4{color:var(--white);font-weight:700;font-size:.97rem;margin-bottom:5px;}
.acard p{color:rgba(255,255,255,0.62);font-size:.85rem;line-height:1.6;}

/* SERVICES */
#services{background:var(--cream);}
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.scard{background:var(--white);border-radius:20px;padding:30px;border:1px solid var(--border);transition:.35s;cursor:pointer;position:relative;overflow:hidden;}
.scard::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--teal),var(--teal-mid));opacity:0;transition:.35s;z-index:0;}
.scard:hover{transform:translateY(-6px);box-shadow:var(--shadow-lg);}
.scard:hover::after{opacity:1;}
.scard>*{position:relative;z-index:1;}
.scard:hover .sc-icon{background:var(--gold);}
.scard:hover .sc-title,.scard:hover .sc-desc,.scard:hover .sc-more{color:var(--white)!important;}
.sc-icon{width:52px;height:52px;background:rgba(13,51,71,0.08);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:20px;transition:.3s;}
.sc-title{font-weight:700;font-size:1rem;color:var(--teal);margin-bottom:12px;transition:.3s;}
.sc-desc{font-size:.87rem;color:var(--text-mid);line-height:1.7;margin-bottom:20px;transition:.3s;}
.sc-more{font-size:.82rem;font-weight:700;color:var(--gold);transition:.3s;}
.scard.feat{background:linear-gradient(135deg,var(--teal),var(--teal-mid));border-color:transparent;}
.scard.feat::after{display:none;}
.scard.feat .sc-title,.scard.feat .sc-more{color:var(--white);}
.scard.feat .sc-desc{color:rgba(255,255,255,0.7);}
.scard.feat .sc-icon{background:var(--gold);}

/* HOW IT WORKS */
#how{background:var(--white);}
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:40px;position:relative;}
.steps::before{content:'';position:absolute;top:55px;left:calc(16.5% + 20px);right:calc(16.5% + 20px);height:2px;background:linear-gradient(90deg,var(--gold),var(--teal));z-index:0;}
.step{text-align:center;position:relative;z-index:1;}
.step-ring{width:110px;height:110px;border-radius:50%;border:3px solid var(--gold);margin:0 auto 24px;display:flex;align-items:center;justify-content:center;font-size:2.8rem;position:relative;background:var(--cream);transition:.3s;}
.step-ring:hover{background:var(--gold);transform:scale(1.05);}
.step-badge{position:absolute;bottom:-10px;right:-10px;width:32px;height:32px;background:var(--teal);color:var(--gold-bright);border-radius:50%;font-weight:800;font-size:.82rem;display:flex;align-items:center;justify-content:center;border:2px solid var(--white);}
.step h3{font-weight:700;color:var(--teal);margin-bottom:10px;}
.step p{font-size:.87rem;color:var(--text-mid);line-height:1.7;}

/* PLAN */
#plan{background:var(--cream);}
.plan-grid{display:grid;grid-template-columns:1fr 1fr;gap:28px;}
.pcard{background:linear-gradient(160deg,var(--teal),var(--teal-mid));border-radius:22px;padding:40px;}
.pcard.light{background:var(--white);border:1px solid var(--border);}
.pcard h3{font-family:'Playfair Display',serif;font-size:1.6rem;color:var(--white);margin-bottom:14px;}
.pcard.light h3{color:var(--teal);}
.pcard>p{font-size:.92rem;line-height:1.75;color:rgba(255,255,255,0.72);margin-bottom:28px;}
.pcard.light>p{color:var(--text-mid);}
.p-lbl{font-size:.78rem;font-weight:800;letter-spacing:.1em;color:var(--gold-bright);margin-bottom:16px;text-transform:uppercase;}
.pcard.light .p-lbl{color:var(--gold);}
.pcard ul{list-style:none;display:flex;flex-direction:column;gap:12px;margin-bottom:32px;}
.pcard ul li{display:flex;align-items:center;gap:12px;font-size:.9rem;color:rgba(255,255,255,0.82);}
.pcard.light ul li{color:var(--text-mid);}
.pcard ul li::before{content:'✓';width:22px;height:22px;background:var(--gold);color:var(--teal);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;flex-shrink:0;}

/* TESTIMONIALS */
#testimonials{background:var(--white);}
.testi-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;}
.tcard{background:var(--cream);border-radius:20px;padding:32px;border:1px solid var(--border);transition:.25s;}
.tcard:hover{box-shadow:var(--shadow);transform:translateY(-4px);}
.tcard-head{display:flex;align-items:center;gap:16px;margin-bottom:20px;}
.tcard-av{width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;flex-shrink:0;}
.tcard-name{font-weight:700;color:var(--teal);font-size:.97rem;}
.tcard-role{font-size:.78rem;color:var(--text-light);margin-bottom:5px;}
.stars{color:var(--gold);letter-spacing:2px;font-size:.85rem;}
.tcard-q{font-size:.9rem;line-height:1.78;color:var(--text-mid);font-style:italic;position:relative;padding-top:16px;}
.tcard-q::before{content:'\201C';font-family:'Playfair Display',serif;font-size:3.5rem;color:var(--gold);line-height:0;position:absolute;top:20px;left:0;}
.tcard-qi{padding-left:28px;}

/* EVENTS */
#events{background:var(--cream);}
.events-list{display:flex;flex-direction:column;gap:20px;}
.erow{background:var(--white);border-radius:18px;border:1px solid var(--border);display:grid;grid-template-columns:130px 1fr auto;overflow:hidden;transition:.25s;}
.erow:hover{box-shadow:var(--shadow);transform:translateY(-3px);}
.ethumb{display:flex;align-items:center;justify-content:center;font-size:2.8rem;}
.ebody{padding:22px 28px;}
.eloc{font-size:.78rem;color:var(--text-light);margin-bottom:6px;}
.etitle{font-weight:700;color:var(--teal);font-size:1rem;margin-bottom:10px;}
.ehost{display:flex;align-items:center;gap:10px;font-size:.82rem;color:var(--text-mid);margin-bottom:14px;}
.eav{width:30px;height:30px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;color:var(--teal);flex-shrink:0;}
.ebox{background:var(--teal);padding:20px 28px;display:flex;flex-direction:column;align-items:center;justify-content:center;min-width:120px;}
.ebox-mo{font-size:.72rem;font-weight:700;letter-spacing:.1em;color:rgba(255,255,255,0.65);margin-bottom:4px;}
.ebox-d{font-family:'Playfair Display',serif;font-size:2.8rem;color:var(--gold-bright);line-height:1;}
.ebox-t{font-size:.7rem;color:rgba(255,255,255,0.5);margin-top:6px;}

/* AWARDS */
#awards{background:linear-gradient(160deg,var(--teal-mid),var(--teal));padding:100px 5%;}
.aw-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
.aw-ey{font-size:.72rem;font-weight:800;letter-spacing:.2em;color:var(--gold-bright);text-transform:uppercase;display:block;margin-bottom:14px;}
.aw-inner h2{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3vw,2.6rem);color:var(--white);margin-bottom:18px;line-height:1.25;}
.aw-inner p{color:rgba(255,255,255,0.7);line-height:1.8;margin-bottom:32px;}
.aw-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.aw-b{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:14px;padding:20px 16px;display:flex;flex-direction:column;align-items:center;gap:8px;transition:.3s;}
.aw-b:hover{background:rgba(212,149,42,0.15);border-color:rgba(212,149,42,0.3);transform:translateY(-3px);}
.aw-b-icon{font-size:2rem;}
.aw-b-lbl{font-size:.72rem;color:rgba(255,255,255,0.65);text-align:center;font-weight:600;line-height:1.4;}

/* ARTICLES */
#articles{background:var(--white);}
.art-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.art-card{border-radius:20px;overflow:hidden;border:1px solid var(--border);transition:.3s;}
.art-card:hover{box-shadow:var(--shadow-lg);transform:translateY(-5px);}
.art-thumb{height:190px;display:flex;align-items:center;justify-content:center;font-size:2.5rem;}
.art-body{padding:24px;}
.art-tag{font-size:.7rem;font-weight:800;letter-spacing:.12em;color:var(--gold);margin-bottom:10px;text-transform:uppercase;}
.art-title{font-weight:700;color:var(--teal);margin-bottom:14px;font-size:.95rem;line-height:1.5;}
.art-link{font-size:.83rem;font-weight:600;color:var(--text-mid);display:flex;align-items:center;gap:6px;text-decoration:none;transition:.2s;}
.art-link:hover{color:var(--teal);}

/* QR SECTION */
#qr-section{background:var(--cream);padding:100px 5%;}
.qr-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;}
.qr-card{background:var(--white);border-radius:24px;padding:36px 28px;border:1px solid var(--border);text-align:center;transition:.3s;position:relative;overflow:hidden;cursor:pointer;}
.qr-card::before{content:'';position:absolute;inset:0;background:linear-gradient(160deg,var(--teal),var(--teal-mid));opacity:0;transition:.4s;z-index:0;}
.qr-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-lg);}
.qr-card:hover::before{opacity:1;}
.qr-card:hover .qr-lbl,.qr-card:hover .qr-val,.qr-card:hover .qr-hint{color:var(--white)!important;}
.qr-card:hover .qr-icon-w{background:var(--gold);}
.qr-card:hover .qr-box{border-color:var(--gold-bright);box-shadow:0 0 0 4px rgba(240,183,58,0.25);}
.qr-card:hover .qr-tag{background:rgba(255,255,255,0.18);color:var(--white);}
.qr-card>*{position:relative;z-index:1;}
.qr-icon-w{width:52px;height:52px;background:rgba(13,51,71,0.08);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin:0 auto 20px;transition:.3s;}
